{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "스토리시드 기본 권한: 폴더 선택 대화상자 + 선택한 작품 폴더(숨김 폴더 포함) 읽기/쓰기",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "**" },
        { "path": "**/*" },
        { "path": "**/.*" },
        { "path": "**/.*/**" }
      ]
    },
    "updater:default",
    "process:default",
    "process:allow-restart",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        {
          "path": "**"
        },
        {
          "path": "**/*"
        },
        {
          "path": "**/.*"
        },
        {
          "path": "**/.*/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        {
          "path": "**"
        },
        {
          "path": "**/*"
        },
        {
          "path": "**/.*"
        },
        {
          "path": "**/.*/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "**"
        },
        {
          "path": "**/*"
        },
        {
          "path": "**/.*"
        },
        {
          "path": "**/.*/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        {
          "path": "**"
        },
        {
          "path": "**/*"
        },
        {
          "path": "**/.*"
        },
        {
          "path": "**/.*/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        {
          "path": "**"
        },
        {
          "path": "**/*"
        },
        {
          "path": "**/.*"
        },
        {
          "path": "**/.*/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        {
          "path": "**"
        },
        {
          "path": "**/*"
        },
        {
          "path": "**/.*"
        },
        {
          "path": "**/.*/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        {
          "path": "**"
        },
        {
          "path": "**/*"
        },
        {
          "path": "**/.*"
        },
        {
          "path": "**/.*/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "**"
        },
        {
          "path": "**/*"
        },
        {
          "path": "**/.*"
        },
        {
          "path": "**/.*/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        {
          "path": "**"
        },
        {
          "path": "**/*"
        },
        {
          "path": "**/.*"
        },
        {
          "path": "**/.*/**"
        }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "**"
        },
        {
          "path": "**/*"
        },
        {
          "path": "**/.*"
        },
        {
          "path": "**/.*/**"
        }
      ]
    }
  ]
}